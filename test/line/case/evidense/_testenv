#
# JSONダンプ
# 人間が目視で確認しやすい形式(pretty形式)にJSONを変換する
# @param 1) 入力JSONファイル
# @param 2) 出力JSONファイル
dump_pretty_json() {
        if [ $# -ne 2 ] ; then
                echo_cmd "Miss arguments. at:diff_json"
                return 1
        fi
        jq -S . ${1} >${2}
        return $?
}

#
# JSON差分比較
# @param 1) 期待JSON。JSONとして期待する値を格納するファイル
# @param 2) 評価JSON。JSONとして評価する値を格納するファイル
# @param 3..) sedルール。期待JSONと評価JSONで許容される差分を指定する。
#             (省略時は、sedを実行しない)
diff_json() {
        local sed_rule=""
        if [ $# -lt 2 ] ; then
                echo_cmd "Miss arguments. at:diff_json"
                return 1
        fi

        exp_json=${1}
        act_json=${2}
        shift
        shift
        if [ $# -gt 0 ] ; then
                sed_rule="$*"
        fi

        if [ -z "${sed_rule}" ] ; then
                exec_cmd diff \
                        <(jq -S . ${exp_json}) \
                        <(jq -S . ${act_json}) \
                        >/dev/null
        else
                exec_cmd diff \
                        <(jq -S . ${exp_json} | sed -e ${sed_rule}) \
                        <(jq -S . ${act_json} | sed -e ${sed_rule}) \
                        >/dev/null
        fi
        return $?
}
