# 試験環境にあわせた設定ファイルを作成する。
# @param 1) template形式の設定ファイル格納ディレクトリパス
#           ※本ディレクトリに配置されたファイルには、以下の処理が実施される。
#             - ファイル名が"XXX.template"  --> 本ファイル内のテンプレート文字列を試験環境にあわせたパスに
#                                               変換したうえで、param2で指定したディレクトリにコピーされる。
#             - 上記以外のファイル名        --> そのままparam2で指定したディレクトリにコピーされる。
# @param 2) template形式から変換した設定ファイル格納ディレクトリパス
convert_conf () {
    local -r src_dir=$1
    local -r dst_dir=$2
    for file in `find ${src_dir} -type l -o -type f`;do
        # テンプレート形式のファイルの場合
        if [ "${file##*.}" = "template" ] ; then
            # テンプレート文字列を各種パスに変換したうえで設定ファイル格納ディレクトリに配置する。
             sed ${file} > ${dst_dir}/$(basename ${file%.template}) \
                -e "s:%%RELEASE_DIR%%:$(get_abs_path ${release_dir}):g"
        # テンプレート形式のファイル以外の場合
        else
            # 何もせず、同じファイルを設定ファイル格納ディレクトリに配置する。
            cp ${file} ${dst_dir}
        fi
    done
}

#############################################################################
# 試験用出力ログ保持
# Docker環境での試験(run_docker.shでの起動時)を考慮し、
# 変数log_dir_non_clearが定義されている場合、ログディレクトリのクリアを行わない
#############################################################################

# ログディレクトリがなかったら作成
if [ ! -d ${log_dir} ];then
        mkdir -p ${log_dir}
else
        # ログディレクトリ配下の資材をクリア
        # 拡張子付きファイルのみ削除。サブディレクトリがある場合はテストスクリプト側で制御すること
    if [ ! -v log_dir_non_clear ];then
                rm -r ${log_dir}/*.* || true
    fi
fi

exec 1>> >(tee ${log_dir}/`basename ${0}`.stdout.log)
exec 2>> >(tee ${log_dir}/`basename ${0}`.stderr.log)

